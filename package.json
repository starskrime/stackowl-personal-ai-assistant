{
  "name": "stackowl-personal-ai-assistant",
  "version": "0.1.1",
  "description": "🦉 StackOwl — A vendor-agnostic personal AI assistant with multi-owl personalities, Parliament brainstorming, Instincts, Pellets, and Owl DNA evolution.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "stackowl": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp -r src/owls/defaults dist/owls/defaults && cp -r src/skills/defaults dist/skills/defaults",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "stackowl": "tsx src/index.ts",
    "tool:create": "tsx scripts/create-tool.ts",
    "test:heap": "node --expose-gc ./node_modules/.bin/vitest run __tests__/tui-v2/heap-canary.test.ts",
    "test:adapters": "vitest run __tests__/tui-v2/adapter-conformance.test.ts",
    "test:bench": "vitest bench __tests__/tui-v2/performance.bench.ts"
  },
  "keywords": [
    "ai-assistant",
    "ollama",
    "local-ai",
    "multi-agent",
    "personal-assistant",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@clack/prompts": "^1.3.0",
    "@crawlee/puppeteer": "^3.16.0",
    "@ffmpeg/core": "^0.11.0",
    "@ffmpeg/ffmpeg": "^0.11.6",
    "@google/genai": "^1.50.1",
    "@grammyjs/auto-retry": "^2.0.2",
    "@huggingface/transformers": "^4.0.1",
    "@inkjs/ui": "^2.0.0",
    "@lancedb/lancedb": "^0.16.0",
    "@slack/bolt": "^4.6.0",
    "@types/dockerode": "^4.0.1",
    "@types/react": "^19.2.14",
    "3d-force-graph": "^1.80.0",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "claude-flow": "^3.5.51",
    "commander": "^13.1.0",
    "cosine-similarity": "^1.0.0",
    "crawlee": "^3.16.0",
    "debug": "^4.4.3",
    "dockerode": "^4.0.9",
    "express": "^5.2.1",
    "fastembed": "^2.1.0",
    "fdir": "^6.5.0",
    "grammy": "^1.41.1",
    "graphology": "^0.26.0",
    "graphology-components": "^1.5.4",
    "graphology-traversal": "^0.3.1",
    "gray-matter": "^4.0.3",
    "ink": "^6.8.0",
    "kuzu": "^0.8.2",
    "mammoth": "^1.12.0",
    "ogg-opus-decoder": "^1.7.3",
    "ollama": "^0.5.14",
    "onnxruntime-node": "^1.24.3",
    "openai": "^6.34.0",
    "pdf-parse": "^2.4.5",
    "puppeteer": "^24.38.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.2.6",
    "uuid": "^11.1.0",
    "ws": "^8.18.1",
    "yaml": "^2.7.0",
    "zustand": "^5.0.13"
  },
  "optionalDependencies": {
    "camofox-browser": "^2.1.1",
    "naudiodon": "^2.3.6",
    "nodejs-whisper": "^0.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.10",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.14",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.22.0",
    "globals": "^17.5.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
