{
  "name": "stackowl-personal-ai-assistant",
  "version": "0.1.0",
  "description": "🦉 StackOwl — A vendor-agnostic personal AI assistant with multi-owl personalities, Parliament brainstorming, Instincts, Pellets, and Owl DNA evolution.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "stackowl": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp -r src/owls/defaults dist/owls/defaults && cp -r src/skills/defaults dist/skills/defaults",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "stackowl": "tsx src/index.ts"
  },
  "keywords": [
    "ai-assistant",
    "ollama",
    "local-ai",
    "multi-agent",
    "personal-assistant",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@crawlee/puppeteer": "^3.16.0",
    "@grammyjs/auto-retry": "^2.0.2",
    "@huggingface/transformers": "^4.0.1",
    "@lancedb/lancedb": "^0.16.0",
    "@slack/bolt": "^4.6.0",
    "@types/dockerode": "^4.0.1",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "claude-flow": "^3.5.51",
    "commander": "^13.1.0",
    "cosine-similarity": "^1.0.0",
    "crawlee": "^3.16.0",
    "dockerode": "^4.0.9",
    "express": "^5.2.1",
    "fastembed": "^2.1.0",
    "grammy": "^1.41.1",
    "graphology": "^0.26.0",
    "graphology-components": "^1.5.4",
    "graphology-traversal": "^0.3.1",
    "gray-matter": "^4.0.3",
    "kuzu": "^0.8.2",
    "ollama": "^0.5.14",
    "onnxruntime-node": "^1.24.3",
    "puppeteer": "^24.38.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.10",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.14",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
