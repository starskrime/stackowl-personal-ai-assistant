.venv/
# Machine-local uv config + relocated cache (host-specific absolute paths).
uv.toml
.uv-cache/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
.ruff_cache/
stackowl.yaml
.dev-home/

# Runtime state/artifacts must live under ~/.stackowl/ (StackowlHome), never the project.
# These guard against stray writes if a process ever runs with the wrong CWD.
/data/
/downloads/
*.mp4
*.mov
*.mkv
*.webm
.claude/*
!.claude/skills/
.claude/skills/*
!.claude/skills/tonyStyle/
_bmad/
logs/
.bmad-loop/runs/
.bmad-loop/cache/
.bmad-loop/policy.toml

# graphify — regenerated locally via post-commit/post-checkout hooks (graphify hook install)
graphify-out/

# Local git worktrees (superpowers:using-git-worktrees)
.worktrees/
